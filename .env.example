# Doot configuration. Copy to .env and fill in. The same image runs locally and in the cloud;
# only these values change. .env is gitignored - never commit secrets.

# --- Database -------------------------------------------------------------
# The durable store is libSQL/SQLite. Set a libSQL/Turso URL (file:, libsql://,
# http(s)://) or leave unset to use the default local file (file:./.data/doot.sqlite).
# NOTE: Postgres is NOT wired yet - a postgres:// URL silently FALLS BACK to the
# local SQLite file with a warning. (DO Managed Postgres is a planned follow-up.)
# DATABASE_URL=file:./.data/doot.sqlite

# --- Backups (automatic when object storage below is configured) ----------
# A consistent VACUUM INTO snapshot is uploaded (PRIVATE) to the object store
# hourly. Tune or disable:
# BACKUP_INTERVAL_MS=3600000
# DOOT_BACKUP_DISABLED=1

# --- Auth -----------------------------------------------------------------
# Secret used to seal httpOnly session cookies. Generate a long random value.
SESSION_PASSWORD=change-me-to-a-long-random-string-at-least-32-chars

# --- Admin ----------------------------------------------------------------
# The FIRST account ever created is auto-promoted to admin (once, forever). This var
# is an optional override: emails listed here always have admin access (independent of
# the DB, so the owner can't be locked out), and it tells the first-admin bootstrap
# which existing account to promote when several already exist. See docs/admin.md.
# DOOT_ADMIN_EMAILS=you@example.com

# --- Object storage (DigitalOcean Spaces in cloud, MinIO locally) ---------
SPACES_ENDPOINT=http://localhost:9000
SPACES_REGION=us-east-1
SPACES_BUCKET=doot
SPACES_KEY=minioadmin
SPACES_SECRET=minioadmin

# --- App ------------------------------------------------------------------
# Site origin, used to build join links and QR codes.
PUBLIC_BASE_URL=http://localhost:3000

# --- Observability (optional) ---------------------------------------------
# Server + client errors are always captured into an in-memory ring shown in the
# admin console (/admin -> Status), alongside the last DB backup. Set a Slack/
# Discord-style incoming webhook to ALSO get a throttled push alert on errors.
# DOOT_ERROR_WEBHOOK=https://hooks.slack.com/services/...

# --- Real-time relay ------------------------------------------------------
CLASP_RELAY_URL=wss://relay.clasp.to

# --- Analytics (optional; self-hosted GoatCounter) ------------------------
# Origin of your GoatCounter instance. Leave unset to disable analytics (no
# tracking script is loaded). Set it after you create the site to switch on
# privacy-friendly, cookie-free pageview tracking. NUXT_PUBLIC_ prefix so Nuxt
# applies it to runtimeConfig.public at RUNTIME (no rebuild). See docs/deploy.md.
# NUXT_PUBLIC_GOATCOUNTER_URL=https://stats.doot.games

# --- TURN relay (optional; for the Retro Arcade spectator stream) ----------
# WebRTC uses public STUN by default. For viewers behind NATs that STUN can't
# traverse, point at a TURN server you run (CLASP is signaling-only, NOT a TURN
# server). NUXT_PUBLIC_ prefix so Nuxt applies it at RUNTIME. url may be a
# comma-separated list. Empty = STUN-only. See docs/deploy.md.
# NUXT_PUBLIC_TURN_URL=turn:turn.doot.games:3478,turns:turn.doot.games:5349
# NUXT_PUBLIC_TURN_USERNAME=doot
# NUXT_PUBLIC_TURN_CREDENTIAL=change-me

# --- Email (optional; only needed for magic-link sign-in) -----------------
# SMTP_HOST=
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASS=
# SMTP_FROM=Doot <noreply@example.com>
